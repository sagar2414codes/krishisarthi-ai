# ──────────────────────────────────────────────────────────────────────────────
# KrishiSarthi AI — Environment Variables Template
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Public URL of the deployed backend API.
# Development default: http://127.0.0.1:7860
# Production example:  https://krishisarthi-backend.up.railway.app
VITE_API_BASE_URL=http://127.0.0.1:7860

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# Use "*" to allow all origins (development only).
# Production example: https://krishisarthi.vercel.app,https://www.krishisarthi.com
ALLOWED_ORIGINS=*

# Port the backend server listens on (Railway injects $PORT automatically).
PORT=7860

# ── Docker Hub (CI/CD) ────────────────────────────────────────────────────────
# Set these as GitHub repository secrets, not in this file.
# DOCKER_USERNAME=your-dockerhub-username
# DOCKER_PASSWORD=your-dockerhub-token

# ── Vercel (CI/CD) ────────────────────────────────────────────────────────────
# VERCEL_TOKEN=your-vercel-token
# VERCEL_ORG_ID=your-vercel-org-id
# VERCEL_PROJECT_ID=your-vercel-project-id

# ── Railway (CI/CD) ───────────────────────────────────────────────────────────
# RAILWAY_TOKEN=your-railway-api-token
